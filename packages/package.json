{
  "name": "pintureria-erp",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "db:migrate": "turbo run db:migrate --filter=@erp/db",
    "db:generate": "turbo run db:generate --filter=@erp/db",
    "db:seed": "turbo run db:seed --filter=@erp/db",
    "db:studio": "turbo run db:studio --filter=@erp/db"
  },
  "devDependencies": {
    "turbo": "^2.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
