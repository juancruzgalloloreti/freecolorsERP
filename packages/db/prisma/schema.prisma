// ============================================================
// SCHEMA PRISMA — ERP Pinturería
// Principios:
//   · Stock basado en movimientos (inmutable, auditable)
//   · CC como vista derivada: saldo = SUM(amount)
//   · CUIT: UNIQUE parcial (raw migration, ver abajo)
//   · Remito ó Factura directa, nunca ambos
//   · Multi-tenant con RLS en PostgreSQL
//   · Costos: promedio ponderado incremental en la API
// ============================================================

generator client {
  provider        = "prisma-client-js"
  // Output explícito — evita conflictos en monorepos con pnpm
  // BUG FIX: se committeó sólo el binario de Windows (.dll.node).
  // "native" resuelve el binario correcto para la plataforma actual.
  // Los targets extra permiten deployar en Debian/Ubuntu y Alpine (Docker).
  binaryTargets   = ["native", "debian-openssl-3.0.x", "linux-musl-openssl-3.0.x"]
  previewFeatures = ["relationJoins"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// TENANT
// ─────────────────────────────────────────────────────────────

model Tenant {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  plan      Plan     @default(FREE)
  isActive  Boolean  @default(true)
  settings  Json     @default("{}") // configuraciones por tenant
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users          User[]
  products       Product[]
  categories     Category[]
  brands         Brand[]
  deposits       Deposit[]
  documents      Document[]
  salesOrders    SalesOrder[]
  payments       Payment[]
  ccEntries      CurrentAccountEntry[]
  customers      Customer[]
  suppliers      Supplier[]
  priceLists     PriceList[]
  priceCoefficients PriceCoefficient[]
  puntoDeVentas  PuntoDeVenta[]
  stockMovements StockMovement[]
  auditLogs      AuditLog[]
  cashSessions   CashSession[]
  cashMovements  CashMovement[]
  documentSequences DocumentSequence[]
  afipCredential AfipCredential?
  supplierProducts SupplierProduct[]
  supplierAccountEntries SupplierAccountEntry[]
  checks Check[]
  exchangeRates ExchangeRate[]
  idempotencyKeys IdempotencyKey[]
  purchaseOrders PurchaseOrder[]
  purchaseReceptions PurchaseReception[]
  approvalFlows ApprovalFlow[]
  approvalRequests ApprovalRequest[]
  documentConversions DocumentConversion[]

  @@map("tenants")
}

enum Plan {
  FREE
  BASIC
  PRO
}

// ─────────────────────────────────────────────────────────────
// USER & AUTH
// ─────────────────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  tenantId           String
  email              String
  passwordHash       String
  firstName          String
  lastName           String
  role               UserRole  @default(EMPLOYEE)
  isActive           Boolean   @default(true)
  // Refresh tokens — rotation + reuse detection (ver RefreshToken)
  refreshTokens      RefreshToken[]
  lastLoginAt        DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents Document[] @relation("DocumentCreatedBy")
  salesOrders SalesOrder[] @relation("SalesOrderCreatedBy")
  stockMovements StockMovement[] @relation("StockMovementCreatedBy")
  payments Payment[] @relation("PaymentCreatedBy")
  ccEntries CurrentAccountEntry[] @relation("CurrentAccountEntryCreatedBy")
  cashMovements CashMovement[] @relation("CashMovementCreatedBy")
  userPermissions UserPermission[]
  purchaseOrders PurchaseOrder[] @relation("PurchaseOrderCreatedBy")
  purchaseReceptions PurchaseReception[] @relation("PurchaseReceptionCreatedBy")
  approvalRequests ApprovalRequest[] @relation("ApprovalRequestRequestedBy")
  approvalDecisions ApprovalDecision[] @relation("ApprovalDecisionUser")
  documentConversions DocumentConversion[] @relation("DocumentConversionCreatedBy")

  @@unique([tenantId, email])
  @@index([tenantId, role])
  @@map("users")
}

enum UserRole {
  OWNER    // dueño, acceso total
  ADMIN    // administrador
  EMPLOYEE // vendedor / cajero
  READONLY // solo lectura / contador
}

// ─────────────────────────────────────────────────────────────
// PERMISSIONS
// ─────────────────────────────────────────────────────────────

model Permission {
  id          String   @id @default(cuid())
  code        String   @unique // ej: "sale.create", "stock.adjust"
  description String
  category    String   // ej: "sales", "stock", "cash", "customers"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users UserPermission[]

  @@index([category])
  @@map("permissions")
}

model UserPermission {
  id           String      @id @default(cuid())
  userId       String
  permissionId String
  grantedAt    DateTime    @default(now())

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionId])
  @@index([userId])
  @@map("user_permissions")
}

// ─────────────────────────────────────────────────────────────
// REFRESH TOKENS — Rotation + Reuse Detection
// ─────────────────────────────────────────────────────────────

model RefreshToken {
  id         String    @id @default(cuid())
  familyId   String                        // agrupa tokens de una misma sesión
  tokenHash  String    @unique             // SHA-256 del token real, nunca el crudo
  userId     String
  expiresAt  DateTime
  revokedAt  DateTime?                     // null = activo; !null = rotado o invalidado
  createdAt  DateTime  @default(now())

  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([familyId])
  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// CATÁLOGO
// ─────────────────────────────────────────────────────────────

model Category {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  parentId  String?  // árbol recursivo
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent   Category?  @relation("CategoryTree", fields: [parentId], references: [id])
  children Category[] @relation("CategoryTree")
  products Product[]
  priceCoefficients PriceCoefficient[]

  @@unique([tenantId, name, parentId])
  @@index([tenantId, parentId])
  @@map("categories")
}

model Brand {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  products Product[]

  @@unique([tenantId, name])
  @@map("brands")
}

model Product {
  id          String   @id @default(cuid())
  tenantId    String
  code        String   // UNIQUE por tenant
  barcode     String?
  barcodeAlt  String?
  name        String
  description String?
  categoryId  String?
  brandId     String?
  // Unidad: un, lt, kg, m2, m, caja, etc.
  unit        String   @default("un")
  purchaseUnitCoefficient Decimal? @db.Decimal(18, 4)
  taxRate     Decimal  @default(21) @db.Decimal(5, 2)
  replacementCost Decimal? @db.Decimal(18, 4)
  averageCost Decimal? @db.Decimal(18, 4)
  lastPurchaseCost Decimal? @db.Decimal(18, 4)
  minStock    Decimal? @db.Decimal(18, 4)
  maxStock    Decimal? @db.Decimal(18, 4)
  baseCurrency String  @default("ARS")
  basePrice    Decimal? @db.Decimal(18, 4)
  isActive    Boolean  @default(true)
  // Notas internas
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category       Category?       @relation(fields: [categoryId], references: [id])
  brand          Brand?          @relation(fields: [brandId], references: [id])
  stockMovements StockMovement[]
  documentItems  DocumentItem[]
  salesOrderItems SalesOrderItem[]
  priceListItems PriceListItem[]
  priceCoefficients PriceCoefficient[]
  supplierProducts SupplierProduct[]
  variants       ProductVariant[]
  purchaseOrderItems PurchaseOrderItem[]

  @@unique([tenantId, code])
  @@index([tenantId, barcode])
  @@index([tenantId, barcodeAlt])
  @@index([tenantId, categoryId])
  @@index([tenantId, brandId])
  @@map("products")
}

// ─────────────────────────────────────────────────────────────
// STOCK (tabla inmutable — nunca UPDATE/DELETE)
// ─────────────────────────────────────────────────────────────

model Deposit {
  id        String   @id @default(cuid())
  tenantId  String
  name      String
  address   String?
  isDefault Boolean  @default(false)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]
  purchaseReceptions PurchaseReception[]

  @@unique([tenantId, name])
  @@map("deposits")
}

model StockMovement {
  id          String            @id @default(cuid())
  tenantId    String
  productId   String
  depositId   String
  type        StockMovementType
  // quantity: + entrada, - salida
  quantity    Decimal           @db.Decimal(18, 4)
  // unitCost: costo unitario al momento del movimiento (CPP incremental calculado en la API)
  unitCost    Decimal           @db.Decimal(18, 4)
  documentId  String?           // referencia al documento que originó el movimiento
  variantId   String?
  notes       String?
  createdAt   DateTime          @default(now())
  createdById String?

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product  Product   @relation(fields: [productId], references: [id])
  deposit  Deposit   @relation(fields: [depositId], references: [id])
  document Document? @relation(fields: [documentId], references: [id])
  variant  ProductVariant? @relation(fields: [variantId], references: [id])
  createdBy User?   @relation("StockMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, productId, depositId])
  @@index([tenantId, productId, createdAt])
  @@index([tenantId, documentId])
  @@index([tenantId, variantId])
  @@index([tenantId, depositId, createdAt])
  @@index([tenantId, type, createdAt])
  @@map("stock_movements")
  // Stock actual = SUM(quantity) WHERE tenantId AND productId AND depositId
  // CPP incremental: se calcula en StockService.recordMovement()
}

enum StockMovementType {
  PURCHASE       // entrada por compra
  SALE           // salida por venta
  ADJUSTMENT_IN  // ajuste positivo
  ADJUSTMENT_OUT // ajuste negativo
  TRANSFER_IN    // entrada por transferencia entre depósitos
  TRANSFER_OUT   // salida por transferencia entre depósitos
  RETURN_IN      // devolución recibida de cliente
  RETURN_OUT     // devolución enviada a proveedor
}

// ─────────────────────────────────────────────────────────────
// DOCUMENTOS (Facturas, Remitos, etc.)
// ─────────────────────────────────────────────────────────────

model PuntoDeVenta {
  id        String   @id @default(cuid())
  tenantId  String
  number    Int      // número AFIP (1, 2, 3...)
  name      String   // ej: "Local Principal", "Depósito"
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents Document[]
  documentSequences DocumentSequence[]

  @@unique([tenantId, number])
  @@map("puntos_de_venta")
}

model Document {
  id             String         @id @default(cuid())
  tenantId       String
  type           DocumentType
  status         DocumentStatus @default(DRAFT)
  puntoDeVentaId String?        // null para REMITO / BUDGET
  number         Int?           // correlativo por tipo + PV
  customerId     String?        // para ventas
  supplierId     String?        // para compras
  createdById    String?
  date           DateTime       @default(now())
  dueDate        DateTime?
  notes          String?
  // Snapshot fiscal/delivery at document creation/update time.
  // Keeps historical documents readable even if customer master data changes later.
  customerNameSnapshot         String?
  customerCuitSnapshot         String?
  customerPhoneSnapshot        String?
  customerAddressSnapshot      String?
  customerCitySnapshot         String?
  customerProvinceSnapshot     String?
  customerIvaConditionSnapshot String?
  deliveryAddressSnapshot      String?
  // Totales desnormalizados (calculados al confirmar, inmutables)
  subtotal       Decimal        @db.Decimal(18, 2)
  taxAmount      Decimal        @default(0) @db.Decimal(18, 2)
  total          Decimal        @db.Decimal(18, 2)
  cae            String?
  caeFechaVto    DateTime?
  caeStatus      CaeStatus      @default(PENDING)
  qrData         String?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  tenant         Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  puntoDeVenta   PuntoDeVenta?         @relation(fields: [puntoDeVentaId], references: [id])
  customer       Customer?             @relation(fields: [customerId], references: [id])
  supplier       Supplier?             @relation(fields: [supplierId], references: [id])
  createdBy      User?                 @relation("DocumentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items          DocumentItem[]
  taxes          DocumentTax[]
  stockMovements StockMovement[]
  payments       Payment[]
  ccEntries      CurrentAccountEntry[]
  cashMovements  CashMovement[]
  supplierAccountEntries SupplierAccountEntry[]
  salesOrders    SalesOrder[]

  @@unique([tenantId, puntoDeVentaId, type, number])
  @@index([tenantId, customerId, status])
  @@index([tenantId, supplierId])
  @@index([tenantId, date])
  @@index([tenantId, status, date])
  @@index([tenantId, type, date])
  @@index([tenantId, createdById, date])
  @@map("documents")
}

enum DocumentType {
  INVOICE_A      // Factura A
  INVOICE_B      // Factura B
  INVOICE_C      // Factura C
  CREDIT_NOTE_A  // Nota de Crédito A
  CREDIT_NOTE_B  // Nota de Crédito B
  DEBIT_NOTE_A   // Nota de Débito A
  DEBIT_NOTE_B   // Nota de Débito B
  REMITO         // Remito interno (sin número AFIP)
  PURCHASE_ORDER // Orden de Compra
  PURCHASE_INVOICE // Factura recibida de proveedor
  PURCHASE_CREDIT_NOTE // Nota de crédito de proveedor
  DELIVERY_NOTE  // Remito de entrega
  BUDGET         // Presupuesto
}

enum CaeStatus {
  PENDING
  APPROVED
  REJECTED
  CONTINGENCY
}

enum DocumentStatus {
  DRAFT     // borrador, editable
  CONFIRMED // confirmado, genera stock y CC — inmutable
  CANCELLED // anulado, genera movimientos inversos
}

model SalesOrder {
  id          String           @id @default(cuid())
  tenantId    String
  number      Int
  status      SalesOrderStatus @default(PENDING)
  customerId  String?
  createdById String?
  date        DateTime         @default(now())
  dueDate     DateTime?
  notes       String?
  subtotal    Decimal          @db.Decimal(18, 2)
  taxAmount   Decimal          @default(0) @db.Decimal(18, 2)
  total       Decimal          @db.Decimal(18, 2)
  documentId  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  customer  Customer?        @relation(fields: [customerId], references: [id])
  createdBy User?            @relation("SalesOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  document  Document?        @relation(fields: [documentId], references: [id])
  items     SalesOrderItem[]

  @@unique([tenantId, number])
  @@index([tenantId, status, date])
  @@index([tenantId, customerId, date])
  @@map("sales_orders")
}

enum SalesOrderStatus {
  PENDING
  PREPARATION
  BILLABLE
  INVOICED
  CANCELLED
}

model SalesOrderItem {
  id           String  @id @default(cuid())
  salesOrderId String
  productId    String
  description  String
  quantity     Decimal @db.Decimal(18, 4)
  unitPrice    Decimal @db.Decimal(18, 4)
  discount     Decimal @default(0) @db.Decimal(5, 2)
  taxRate      Decimal @default(0) @db.Decimal(5, 2)
  subtotal     Decimal @db.Decimal(18, 2)
  taxAmount    Decimal @default(0) @db.Decimal(18, 2)
  total        Decimal @db.Decimal(18, 2)
  sortOrder    Int     @default(0)

  salesOrder SalesOrder @relation(fields: [salesOrderId], references: [id], onDelete: Cascade)
  product    Product    @relation(fields: [productId], references: [id])

  @@index([salesOrderId])
  @@index([productId])
  @@map("sales_order_items")
}

model DocumentItem {
  id          String  @id @default(cuid())
  documentId  String
  productId   String?
  description String  // copia del nombre al momento de facturar
  quantity    Decimal @db.Decimal(18, 4)
  unitPrice   Decimal @db.Decimal(18, 4)
  discount    Decimal @default(0) @db.Decimal(5, 2) // porcentaje 0-100
  taxRate     Decimal @default(0) @db.Decimal(5, 2) // porcentaje IVA
  subtotal    Decimal @db.Decimal(18, 2)             // qty * unitPrice * (1 - discount/100)
  taxAmount   Decimal @default(0) @db.Decimal(18, 2)
  total       Decimal @db.Decimal(18, 2)
  sortOrder   Int     @default(0)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  product  Product? @relation(fields: [productId], references: [id])

  @@index([documentId])
  @@map("document_items")
}

model ProductVariant {
  id        String   @id @default(cuid())
  productId String
  name      String
  code      String?
  barcode   String?
  colorHex  String?
  isActive  Boolean  @default(true)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  stockMovements StockMovement[]

  @@unique([productId, name])
  @@index([productId, barcode])
  @@map("product_variants")
}

model DocumentTax {
  id           String      @id @default(cuid())
  documentId   String
  type         TaxLineType
  jurisdiction String?
  base         Decimal     @db.Decimal(18, 2)
  rate         Decimal     @db.Decimal(8, 4)
  amount       Decimal     @db.Decimal(18, 2)

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@map("document_taxes")
}

enum TaxLineType {
  PERCEPCION_IVA
  PERCEPCION_IIBB
  RETENCION_IIBB
  RETENCION_GANANCIAS
}

// ─────────────────────────────────────────────────────────────
// CLIENTES & CUENTA CORRIENTE
// ─────────────────────────────────────────────────────────────

model Customer {
  id           String       @id @default(cuid())
  tenantId     String
  name         String
  email        String?
  phone        String?
  address      String?
  city         String?
  province     String?
  // CUIT: UNIQUE parcial aplicado via raw migration (ver abajo)
  cuit         String?
  ivaCondition IvaCondition @default(CONSUMIDOR_FINAL)
  priceListId  String?
  creditLimit  Decimal?     @db.Decimal(18, 2) // límite de CC, null = sin límite
  isActive     Boolean      @default(true)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant    Tenant                @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  priceList PriceList?            @relation(fields: [priceListId], references: [id])
  documents Document[]
  salesOrders SalesOrder[]
  ccEntries CurrentAccountEntry[]

  @@index([tenantId, isActive])
  @@index([tenantId, priceListId])
  @@map("customers")
  // UNIQUE parcial aplicado en migration:
  // CREATE UNIQUE INDEX uq_customers_tenant_cuit
  //   ON customers(tenant_id, cuit)
  //   WHERE cuit IS NOT NULL;
}

enum IvaCondition {
  RESPONSABLE_INSCRIPTO
  MONOTRIBUTISTA
  CONSUMIDOR_FINAL
  EXENTO
  NO_CATEGORIZADO
}

// Cuenta Corriente: nunca columna editable.
// Saldo = SELECT SUM(amount) FROM current_account_entries WHERE customer_id = ?
model CurrentAccountEntry {
  id          String      @id @default(cuid())
  tenantId    String
  customerId  String
  documentId  String?     // documento que originó la entrada
  type        CcEntryType
  // amount: positivo = cargo (deuda), negativo = abono (pago)
  amount      Decimal     @db.Decimal(18, 2)
  description String
  date        DateTime    @default(now())
  createdAt   DateTime    @default(now())
  createdById String?

  customer Customer  @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id])
  createdBy User?   @relation("CurrentAccountEntryCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([customerId, date])
  @@index([tenantId, date])
  @@index([tenantId, customerId, date])
  @@index([tenantId, type, date])
  @@map("current_account_entries")
}

enum CcEntryType {
  INVOICE     // cargo por factura emitida
  PAYMENT     // abono de pago recibido
  CREDIT_NOTE // abono por nota de crédito
  DEBIT_NOTE  // cargo por nota de débito
  ADJUSTMENT  // ajuste manual con aprobación
}

// ─────────────────────────────────────────────────────────────
// PAGOS
// ─────────────────────────────────────────────────────────────

model Payment {
  id           String        @id @default(cuid())
  tenantId     String
  documentId   String
  method       PaymentMethod
  amount       Decimal       @db.Decimal(18, 2)
  reference    String?       // nro cheque, CBU, últimos 4 dígitos tarjeta, etc.
  date         DateTime      @default(now())
  notes        String?
  createdAt    DateTime      @default(now())
  createdById  String?

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  createdBy User?   @relation("PaymentCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  check    Check?

  @@index([documentId])
  @@index([tenantId, method, date])
  @@index([tenantId, createdById, date])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  CHECK
  CREDIT_CARD
  DEBIT_CARD
  MERCADO_PAGO
  CURRENT_ACCOUNT // pago a cuenta corriente
  OTHER
}

// ─────────────────────────────────────────────────────────────
// CAJA DIARIA
// ─────────────────────────────────────────────────────────────

model CashSession {
  id              String            @id @default(cuid())
  tenantId        String
  openedById      String
  closedById      String?
  status          CashSessionStatus @default(OPEN)
  openedAt        DateTime          @default(now())
  closedAt        DateTime?
  openingAmount   Decimal           @default(0) @db.Decimal(18, 2)
  expectedAmount  Decimal           @default(0) @db.Decimal(18, 2)
  countedAmount   Decimal?          @db.Decimal(18, 2)
  difference      Decimal?          @db.Decimal(18, 2)
  openingNote     String?
  closingNote     String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  tenant    Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  movements CashMovement[]

  @@index([tenantId, status])
  @@index([tenantId, openedAt])
  @@map("cash_sessions")
}

enum CashSessionStatus {
  OPEN
  CLOSED
}

model CashMovement {
  id            String           @id @default(cuid())
  tenantId      String
  sessionId     String
  documentId    String?
  type          CashMovementType
  method        PaymentMethod    @default(CASH)
  amount        Decimal          @db.Decimal(18, 2)
  description   String
  reference     String?
  createdAt     DateTime         @default(now())
  createdById   String

  tenant  Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  session CashSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  document Document?  @relation(fields: [documentId], references: [id])
  createdBy User?     @relation("CashMovementCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, sessionId])
  @@index([tenantId, documentId])
  @@map("cash_movements")
}

enum CashMovementType {
  SALE_PAYMENT
  PURCHASE_PAYMENT
  CASH_IN
  CASH_OUT
  OPENING
  CLOSING_DIFFERENCE
}

model Check {
  id           String      @id @default(cuid())
  tenantId     String
  paymentId    String?     @unique
  number       String
  bank         String
  accountOwner String
  amount       Decimal     @db.Decimal(18, 2)
  issueDate    DateTime
  dueDate      DateTime
  isEcheq      Boolean     @default(false)
  status       CheckStatus @default(RECEIVED)
  notes        String?
  // Endoso
  endorsedTo   String?
  endorsedDate DateTime?
  // Rechazo
  rejectionReason String?
  rejectionDate   DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  payment Payment? @relation(fields: [paymentId], references: [id], onDelete: Cascade)

  @@index([tenantId, dueDate, status])
  @@map("checks")
}

enum CheckStatus {
  RECEIVED
  DEPOSITED
  CLEARED
  BOUNCED
  ENDORSED
  CANCELLED
}

model DocumentSequence {
  id             String       @id @default(cuid())
  tenantId       String
  puntoDeVentaId String?
  scopeKey       String
  documentType   DocumentType
  lastNumber     Int          @default(0)

  tenant       Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  puntoDeVenta PuntoDeVenta?  @relation(fields: [puntoDeVentaId], references: [id])

  @@unique([tenantId, scopeKey, documentType])
  @@index([tenantId, documentType])
  @@map("document_sequences")
}

model AfipCredential {
  id          String   @id @default(cuid())
  tenantId    String   @unique
  cuit        String
  cert        String
  privateKey  String
  environment AfipEnv  @default(TESTING)
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("afip_credentials")
}

enum AfipEnv {
  TESTING
  PRODUCTION
}

// ─────────────────────────────────────────────────────────────
// AUDITORIA
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String
  userId     String?
  action     String
  entityType String
  entityId   String?
  summary    String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, action])
  @@index([tenantId, entityType, entityId])
  @@index([tenantId, createdAt])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// LISTAS DE PRECIO
// ─────────────────────────────────────────────────────────────

model PriceList {
  id                 String   @id @default(cuid())
  tenantId           String
  name               String
  isDefault          Boolean  @default(false)
  isActive           Boolean  @default(true)
  formulaBaseCode    String?
  formulaOperation   String   @default("multiply")
  formulaCoefficient Decimal? @db.Decimal(12, 6)
  formulaRoundingMode String  @default("nearest")
  formulaRoundingValue Decimal? @db.Decimal(18, 4)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  items     PriceListItem[]
  customers Customer[]

  @@unique([tenantId, name])
  @@map("price_lists")
}

model PriceListItem {
  id          String   @id @default(cuid())
  priceListId String
  productId   String
  price       Decimal  @db.Decimal(18, 4)
  isManualOverride Boolean @default(false)
  updatedAt   DateTime @updatedAt

  priceList PriceList @relation(fields: [priceListId], references: [id], onDelete: Cascade)
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([priceListId, productId])
  @@map("price_list_items")
}

model PriceCoefficient {
  id         String                @id @default(cuid())
  tenantId   String
  scope      PriceCoefficientScope
  productId  String?
  categoryId String?
  name       String
  multiplier Decimal               @db.Decimal(12, 6)
  validFrom  DateTime?
  validTo    DateTime?
  isActive   Boolean               @default(true)
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: Cascade)
  category Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  @@index([tenantId, scope, isActive])
  @@index([tenantId, productId, isActive])
  @@index([tenantId, categoryId, isActive])
  @@map("price_coefficients")
}

enum PriceCoefficientScope {
  PRODUCT
  CATEGORY
}

// ─────────────────────────────────────────────────────────────
// PROVEEDORES
// ─────────────────────────────────────────────────────────────

model Supplier {
  id           String       @id @default(cuid())
  tenantId     String
  name         String
  email        String?
  phone        String?
  address      String?
  cuit         String?
  ivaCondition IvaCondition @default(RESPONSABLE_INSCRIPTO)
  isActive     Boolean      @default(true)
  notes        String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  tenant    Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  documents Document[]
  products SupplierProduct[]
  accountEntries SupplierAccountEntry[]
  purchaseOrders PurchaseOrder[]

  @@unique([tenantId, name])
  @@index([tenantId, isActive])
  @@map("suppliers")
}

model SupplierProduct {
  id            String   @id @default(cuid())
  tenantId      String
  supplierId    String
  productId     String
  supplierCode  String?
  supplierName  String?
  lastCost      Decimal? @db.Decimal(18, 4)
  lastOrderDate DateTime?
  leadTimeDays  Int?
  isPreferred   Boolean  @default(false)

  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  product  Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([supplierId, productId])
  @@index([tenantId, productId])
  @@map("supplier_products")
}

model SupplierAccountEntry {
  id          String              @id @default(cuid())
  tenantId    String
  supplierId  String
  documentId  String?
  type        SupplierCcEntryType
  amount      Decimal             @db.Decimal(18, 2)
  description String
  date        DateTime            @default(now())
  createdAt   DateTime            @default(now())

  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier Supplier  @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id])

  @@index([supplierId, date])
  @@index([tenantId, date])
  @@map("supplier_account_entries")
}

enum SupplierCcEntryType {
  PURCHASE
  PAYMENT
  CREDIT_NOTE
  DEBIT_NOTE
  ADJUSTMENT
}

model ExchangeRate {
  id       String   @id @default(cuid())
  tenantId String
  from     String
  to       String
  rate     Decimal  @db.Decimal(18, 6)
  rateType String
  date     DateTime @default(now())

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId, from, to, date])
  @@map("exchange_rates")
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  tenantId     String
  key          String
  method       String
  path         String
  requestHash  String
  status       IdempotencyStatus @default(PROCESSING)
  responseCode Int?
  responseBody Json?
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, key])
  @@index([tenantId, expiresAt])
  @@map("idempotency_keys")
}

enum IdempotencyStatus {
  PROCESSING
  COMPLETED
  FAILED
}

// ─────────────────────────────────────────────────────────────
// COMPRAS
// ─────────────────────────────────────────────────────────────

model PurchaseOrder {
  id           String              @id @default(cuid())
  tenantId     String
  supplierId   String
  number       Int                 // correlativo por tenant
  status       PurchaseOrderStatus @default(PENDING)
  orderDate    DateTime            @default(now())
  expectedDate DateTime?
  notes        String?
  subtotal     Decimal             @db.Decimal(18, 2)
  taxAmount    Decimal             @default(0) @db.Decimal(18, 2)
  total        Decimal             @db.Decimal(18, 2)
  createdById  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  tenant     Tenant               @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supplier   Supplier             @relation(fields: [supplierId], references: [id])
  createdBy  User?                @relation("PurchaseOrderCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items      PurchaseOrderItem[]
  receptions PurchaseReception[]

  @@unique([tenantId, number])
  @@index([tenantId, supplierId])
  @@index([tenantId, status])
  @@map("purchase_orders")
}

enum PurchaseOrderStatus {
  PENDING
  SENT
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
}

model PurchaseOrderItem {
  id               String       @id @default(cuid())
  purchaseOrderId  String
  productId        String
  quantity         Decimal      @db.Decimal(18, 4)
  unitPrice        Decimal      @db.Decimal(18, 4)
  discountPercent  Decimal      @default(0) @db.Decimal(5, 2)
  subtotal         Decimal      @db.Decimal(18, 2)
  taxRate          Decimal      @default(21) @db.Decimal(5, 2)
  taxAmount        Decimal      @default(0) @db.Decimal(18, 2)
  total            Decimal      @db.Decimal(18, 2)
  receivedQuantity Decimal      @default(0) @db.Decimal(18, 4)
  notes            String?

  purchaseOrder PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  product       Product       @relation(fields: [productId], references: [id])
  receptionItems PurchaseReceptionItem[]

  @@index([purchaseOrderId])
  @@index([productId])
  @@map("purchase_order_items")
}

model PurchaseReception {
  id              String                  @id @default(cuid())
  tenantId        String
  purchaseOrderId String
  depositId       String?
  receptionDate   DateTime                @default(now())
  notes           String?
  createdById     String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  tenant         Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  purchaseOrder  PurchaseOrder  @relation(fields: [purchaseOrderId], references: [id])
  deposit        Deposit?       @relation(fields: [depositId], references: [id])
  createdBy      User?           @relation("PurchaseReceptionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  items          PurchaseReceptionItem[]

  @@index([tenantId, receptionDate])
  @@index([tenantId, depositId])
  @@index([purchaseOrderId])
  @@map("purchase_receptions")
}

model PurchaseReceptionItem {
  id                String             @id @default(cuid())
  purchaseReceptionId String
  purchaseOrderItemId String
  quantity          Decimal            @db.Decimal(18, 4)
  notes             String?

  purchaseReception PurchaseReception @relation(fields: [purchaseReceptionId], references: [id], onDelete: Cascade)
  purchaseOrderItem PurchaseOrderItem @relation(fields: [purchaseOrderItemId], references: [id])

  @@index([purchaseReceptionId])
  @@index([purchaseOrderItemId])
  @@map("purchase_reception_items")
}

// ─────────────────────────────────────────────────────────────
// APROBACIONES
// ─────────────────────────────────────────────────────────────

model ApprovalFlow {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  entityType  String   // ej: "Document", "PurchaseOrder"
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tenant    Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  steps     ApprovalStep[]
  requests  ApprovalRequest[]

  @@index([tenantId, entityType])
  @@map("approval_flows")
}

model ApprovalStep {
  id             String         @id @default(cuid())
  approvalFlowId String
  order          Int
  role           UserRole
  requiredCount  Int            // cuántos usuarios con ese rol deben aprobar
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  approvalFlow ApprovalFlow    @relation(fields: [approvalFlowId], references: [id], onDelete: Cascade)

  @@index([approvalFlowId])
  @@map("approval_steps")
}

model ApprovalRequest {
  id             String           @id @default(cuid())
  tenantId       String
  approvalFlowId String
  entityType     String
  entityId       String
  requestedById  String
  status         ApprovalStatus  @default(PENDING)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  approvalFlow  ApprovalFlow     @relation(fields: [approvalFlowId], references: [id])
  requestedBy   User             @relation("ApprovalRequestRequestedBy", fields: [requestedById], references: [id])
  decisions     ApprovalDecision[]

  @@index([tenantId, entityType, entityId])
  @@index([tenantId, status])
  @@map("approval_requests")
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model ApprovalDecision {
  id               String            @id @default(cuid())
  approvalRequestId String
  userId           String
  decision         ApprovalDecisionType
  notes            String?
  createdAt        DateTime          @default(now())

  approvalRequest ApprovalRequest @relation(fields: [approvalRequestId], references: [id], onDelete: Cascade)
  user            User             @relation("ApprovalDecisionUser", fields: [userId], references: [id])

  @@index([approvalRequestId])
  @@index([userId])
  @@map("approval_decisions")
}

enum ApprovalDecisionType {
  APPROVE
  REJECT
}

// ─────────────────────────────────────────────────────────────
// CONVERSIONES DE DOCUMENTOS
// ─────────────────────────────────────────────────────────────

model DocumentConversion {
  id              String   @id @default(cuid())
  tenantId        String
  sourceId        String   // ID del documento origen
  targetType      String   // Tipo de documento destino
  targetId        String?  // ID del documento destino (si ya se creó)
  status          ConversionStatus @default(PENDING)
  error           String?
  createdById     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tenant     Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  createdBy  User?  @relation("DocumentConversionCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)

  @@index([tenantId, sourceId])
  @@index([tenantId, status])
  @@map("document_conversions")
}

enum ConversionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}
